# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# PEXELS_API_KEY: Required for fetching background nature videos.
# Get yours at https://www.pexels.com/api/
PEXELS_API_KEY="MY_PEXELS_API_KEY"

# PIXABAY_API_KEY: Optional alternative for nature videos.
PIXABAY_API_KEY="MY_PIXABAY_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Support Email Settings (for sending emails through SMTP)
# SMTP_HOST: The hostname of your SMTP server (e.g., smtp.gmail.com)
SMTP_HOST=
# SMTP_PORT: The port of your SMTP server (usually 465 or 587)
SMTP_PORT=
# SMTP_USER: Your SMTP username (e.g., alaa0102494@gmail.com)
SMTP_USER=
# SMTP_PASS: Your SMTP password or App Password
SMTP_PASS=
